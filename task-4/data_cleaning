import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
import seaborn as sns
import warnings
warnings.filterwarnings('ignore')

# ─────────────────────────────────────────────
# 1. LOAD DATA
# ─────────────────────────────────────────────
df_raw = pd.read_csv('/home/claude/titanic.csv')
df = df_raw.copy()

print("="*60)
print("TITANIC DATASET — DATA CLEANING REPORT")
print("="*60)

print(f"\n[1] Raw shape: {df.shape[0]} rows × {df.shape[1]} columns")
print("\nColumn dtypes:\n", df.dtypes)
print("\nFirst 5 rows:\n", df.head())

# ─────────────────────────────────────────────
# 2. MISSING VALUES ANALYSIS
# ─────────────────────────────────────────────
missing = df.isnull().sum()
missing_pct = (missing / len(df) * 100).round(2)
missing_df = pd.DataFrame({'Missing Count': missing, 'Missing %': missing_pct})
missing_df = missing_df[missing_df['Missing Count'] > 0].sort_values('Missing %', ascending=False)
print("\n[2] Missing Values Before Cleaning:")
print(missing_df.to_string())

# ─────────────────────────────────────────────
# 3. DUPLICATE ROWS
# ─────────────────────────────────────────────
dupes = df.duplicated().sum()
print(f"\n[3] Duplicate rows: {dupes}")
df.drop_duplicates(inplace=True)

# ─────────────────────────────────────────────
# 4. HANDLE MISSING VALUES
# ─────────────────────────────────────────────
# Age → median imputation
age_median = df['Age'].median()
df['Age'].fillna(age_median, inplace=True)
print(f"\n[4a] Age — filled {missing_df.loc['Age','Missing Count'] if 'Age' in missing_df.index else 0} NaN with median ({age_median})")

# Embarked → mode imputation
embarked_mode = df['Embarked'].mode()[0]
df['Embarked'].fillna(embarked_mode, inplace=True)
print(f"[4b] Embarked — filled NaN with mode ('{embarked_mode}')")

# Cabin → too sparse (>77% missing) → encode as HasCabin flag then drop
df['HasCabin'] = df['Cabin'].notnull().astype(int)
df.drop(columns=['Cabin'], inplace=True)
print("[4c] Cabin — converted to binary flag 'HasCabin', original column dropped")

# ─────────────────────────────────────────────
# 5. DROP LOW-VALUE COLUMNS
# ─────────────────────────────────────────────
df.drop(columns=['PassengerId', 'Name', 'Ticket'], inplace=True)
print("\n[5] Dropped columns: PassengerId, Name, Ticket (high cardinality / no predictive value)")

# ─────────────────────────────────────────────
# 6. ENCODE CATEGORICALS
# ─────────────────────────────────────────────
df['Sex'] = df['Sex'].map({'male': 0, 'female': 1})
embarked_dummies = pd.get_dummies(df['Embarked'], prefix='Embarked', drop_first=True)
df = pd.concat([df.drop(columns=['Embarked']), embarked_dummies], axis=1)
print("\n[6] Encoded: Sex (binary), Embarked (one-hot → Embarked_Q, Embarked_S)")

# ─────────────────────────────────────────────
# 7. OUTLIER DETECTION — Fare (IQR method)
# ─────────────────────────────────────────────
Q1, Q3 = df['Fare'].quantile([0.25, 0.75])
IQR = Q3 - Q1
fare_upper = Q3 + 1.5 * IQR
outliers = (df['Fare'] > fare_upper).sum()
df['Fare'] = df['Fare'].clip(upper=fare_upper)
print(f"\n[7] Fare outliers clipped: {outliers} values above {fare_upper:.2f}")

# ─────────────────────────────────────────────
# 8. FEATURE ENGINEERING
# ─────────────────────────────────────────────
df['FamilySize'] = df['SibSp'] + df['Parch'] + 1
df['IsAlone'] = (df['FamilySize'] == 1).astype(int)
df['AgeGroup'] = pd.cut(df['Age'], bins=[0,12,18,35,60,100],
                        labels=['Child','Teen','YoungAdult','Adult','Senior'])
print("\n[8] New features: FamilySize, IsAlone, AgeGroup")

# ─────────────────────────────────────────────
# 9. FINAL STATE
# ─────────────────────────────────────────────
print(f"\n[9] Cleaned shape: {df.shape[0]} rows × {df.shape[1]} columns")
print("\nRemaining nulls:", df.isnull().sum().sum())
print("\nCleaned dtypes:\n", df.dtypes)
print("\nSample cleaned data:\n", df.head())

df.to_csv('/home/claude/titanic_cleaned.csv', index=False)
print("\n✓ Saved: titanic_cleaned.csv")

# ─────────────────────────────────────────────
# 10. VISUALISATIONS
# ─────────────────────────────────────────────
sns.set_theme(style='whitegrid', palette='muted')
fig = plt.figure(figsize=(18, 14))
fig.suptitle('Titanic Dataset — Data Cleaning Summary', fontsize=16, fontweight='bold', y=0.98)
gs = gridspec.GridSpec(3, 3, figure=fig, hspace=0.45, wspace=0.35)

# (a) Missing values bar — before
ax1 = fig.add_subplot(gs[0, 0])
bars = ax1.barh(missing_df.index, missing_df['Missing %'], color=['#e74c3c','#e67e22','#3498db'])
ax1.set_xlabel('Missing %')
ax1.set_title('Missing Values (Before Cleaning)')
for bar, val in zip(bars, missing_df['Missing %']):
    ax1.text(bar.get_width()+0.5, bar.get_y()+bar.get_height()/2,
             f'{val}%', va='center', fontsize=9)

# (b) Survival count
ax2 = fig.add_subplot(gs[0, 1])
df['Survived'].value_counts().plot(kind='bar', ax=ax2, color=['#e74c3c','#2ecc71'], edgecolor='white')
ax2.set_xticklabels(['Died','Survived'], rotation=0)
ax2.set_title('Survival Distribution')
ax2.set_ylabel('Count')

# (c) Passenger class
ax3 = fig.add_subplot(gs[0, 2])
df['Pclass'].value_counts().sort_index().plot(kind='bar', ax=ax3, color=['#9b59b6','#3498db','#1abc9c'], edgecolor='white')
ax3.set_xticklabels(['1st','2nd','3rd'], rotation=0)
ax3.set_title('Passenger Class Distribution')
ax3.set_ylabel('Count')

# (d) Age distribution after fill
ax4 = fig.add_subplot(gs[1, 0])
ax4.hist(df['Age'], bins=30, color='#3498db', edgecolor='white', alpha=0.85)
ax4.axvline(age_median, color='red', linestyle='--', label=f'Median={age_median}')
ax4.set_title('Age Distribution (After Imputation)')
ax4.set_xlabel('Age')
ax4.legend(fontsize=8)

# (e) Fare distribution after clip
ax5 = fig.add_subplot(gs[1, 1])
ax5.hist(df['Fare'], bins=30, color='#e67e22', edgecolor='white', alpha=0.85)
ax5.set_title('Fare Distribution (After Clipping)')
ax5.set_xlabel('Fare (£)')

# (f) Family size
ax6 = fig.add_subplot(gs[1, 2])
df['FamilySize'].value_counts().sort_index().plot(kind='bar', ax=ax6, color='#1abc9c', edgecolor='white')
ax6.set_title('Family Size Distribution')
ax6.set_xlabel('Family Size')
ax6.set_ylabel('Count')
ax6.tick_params(axis='x', rotation=0)

# (g) Sex distribution
ax7 = fig.add_subplot(gs[2, 0])
df['Sex'].value_counts().plot(kind='bar', ax=ax7, color=['#3498db','#e74c3c'], edgecolor='white')
ax7.set_xticklabels(['Male (0)','Female (1)'], rotation=0)
ax7.set_title('Sex Distribution')

# (h) Age group
ax8 = fig.add_subplot(gs[2, 1])
df['AgeGroup'].value_counts().plot(kind='bar', ax=ax8, color=sns.color_palette('Set2'), edgecolor='white')
ax8.set_title('Age Group Distribution')
ax8.tick_params(axis='x', rotation=20)

# (i) Survival by Sex
ax9 = fig.add_subplot(gs[2, 2])
survival_sex = df.groupby('Sex')['Survived'].mean().rename({0:'Male',1:'Female'})
survival_sex.plot(kind='bar', ax=ax9, color=['#3498db','#e74c3c'], edgecolor='white')
ax9.set_xticklabels(['Male','Female'], rotation=0)
ax9.set_title('Survival Rate by Sex')
ax9.set_ylabel('Survival Rate')
ax9.set_ylim(0, 1)

plt.savefig('/home/claude/titanic_cleaning_report.png', dpi=150, bbox_inches='tight')
print("✓ Saved: titanic_cleaning_report.png")
